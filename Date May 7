<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hey you 💌</title>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #f9a8c9;
    --pink-light: #fde8f1;
    --pink-dark: #e8649a;
    --cream: #fffaf6;
    --warm: #fff3e8;
    --brown: #7a4f3a;
    --red: #e05c5c;
    --green: #6dbb8a;
    --text: #3d2c2c;
    --muted: #a07070;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Caveat', cursive;
    background: var(--cream);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background image placeholder */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: url('https://i.imgur.com/grspp97.png') center/cover no-repeat;
    z-index: -1;
    pointer-events: none;
    opacity: 0.4; /* tweak this to make bg lighter/darker */
  }

  /* PAGE SYSTEM */
  .page {
    display: none;
    min-height: 100vh;
    position: relative;
    z-index: 1;
    animation: fadeIn 0.5s ease;
  }
  .page.active { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem 1.5rem; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* CARD */
  .card {
    background: white;
    border-radius: 24px;
    padding: 2.5rem 2rem;
    max-width: 520px;
    width: 100%;
    box-shadow: 0 8px 40px rgba(200, 100, 140, 0.15), 0 2px 8px rgba(0,0,0,0.05);
    border: 2px dashed #f9c6dc;
    position: relative;
  }

  .card::before {
    content: '';
    position: absolute;
    top: -2px; left: 40px; right: 40px; height: 4px;
    background: linear-gradient(90deg, var(--pink), #ffb3d1, var(--pink));
    border-radius: 0 0 4px 4px;
  }

  /* STICKER decoration */
  .sticker {
    font-size: 2rem;
    display: block;
    text-align: center;
    margin-bottom: 0.5rem;
    animation: wiggle 2s ease-in-out infinite;
  }
  @keyframes wiggle {
    0%, 100% { transform: rotate(-3deg); }
    50% { transform: rotate(3deg); }
  }

  h1 {
    font-family: 'Caveat', cursive;
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--brown);
    text-align: center;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  /* CHOICE BUTTONS (yes/no) */
  .choices {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .choice-btn {
    font-family: 'Caveat', cursive;
    font-size: 1.5rem;
    font-weight: 600;
    padding: 0.75rem 2.5rem;
    border-radius: 50px;
    border: 2.5px solid;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .btn-yes {
    background: var(--pink-light);
    border-color: var(--pink-dark);
    color: var(--pink-dark);
  }
  .btn-yes:hover { background: var(--pink-dark); color: white; transform: scale(1.05); }
  .btn-yes:active { transform: scale(0.97); }

  .btn-no {
    background: #fff5f5;
    border-color: #f0a0a0;
    color: #c06060;
    transition: all 0.3s;
  }

  .btn-no.struck {
    text-decoration: line-through;
    text-decoration-color: var(--red);
    text-decoration-thickness: 3px;
    opacity: 0.45;
    cursor: not-allowed;
    transform: rotate(-2deg);
    pointer-events: none;
  }

  .wala-msg {
    display: none;
    font-size: 1rem;
    color: var(--red);
    text-align: center;
    margin-top: 0.75rem;
    animation: shake 0.4s ease;
    font-weight: 600;
  }
  .wala-msg.show { display: block; }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-8px); }
    40% { transform: translateX(8px); }
    60% { transform: translateX(-5px); }
    80% { transform: translateX(5px); }
  }

  /* FORM SECTION TITLE */
  .section-label {
    font-family: 'Caveat', cursive;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--brown);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* TIME PILLS */
  .time-grid {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .time-pill {
    font-family: 'Caveat', cursive;
    font-size: 1.3rem;
    font-weight: 600;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    border: 2px solid #f0c0d0;
    background: var(--pink-light);
    color: var(--brown);
    cursor: pointer;
    transition: all 0.2s;
  }
  .time-pill:hover { border-color: var(--pink-dark); background: #fdd; }
  .time-pill.selected { background: var(--pink-dark); color: white; border-color: var(--pink-dark); transform: scale(1.06); }

  /* PLACE CARDS */
  .places-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .place-card {
    border-radius: 16px;
    overflow: hidden;
    border: 2.5px solid #f0c0d0;
    cursor: pointer;
    transition: all 0.2s;
    background: white;
    position: relative;
  }
  .place-card:hover { border-color: var(--pink-dark); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(230,100,150,0.2); }
  .place-card.selected { border-color: var(--pink-dark); box-shadow: 0 0 0 3px rgba(232,100,154,0.3); }
  .place-card.selected::after {
    content: '✓';
    position: absolute;
    top: 6px; right: 8px;
    background: var(--pink-dark);
    color: white;
    width: 22px; height: 22px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .place-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .place-img-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fde8f1, #fff0e8);
    font-size: 2rem;
  }

  .place-name {
    font-family: 'Caveat', cursive;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--brown);
    padding: 0.5rem 0.75rem 0.6rem;
    text-align: center;
  }

  .places-hidden {
    display: none;
    animation: fadeIn 0.4s ease;
  }
  .places-hidden.visible { display: grid; }

  .special-label {
    font-size: 1rem;
    color: var(--pink-dark);
    margin-bottom: 0.5rem;
    font-weight: 600;
    text-align: center;
  }

  /* FOOD METER */
  .food-meter {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
    justify-content: center;
    margin: 1rem 0 0.5rem;
  }

  .food-bar-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .food-bar-wrap:hover .food-bar { opacity: 0.85; }
  .food-bar-wrap.selected .food-bar { background: var(--pink-dark) !important; box-shadow: 0 4px 16px rgba(232,100,154,0.4); }
  .food-bar-wrap.selected .food-bar-label { color: var(--pink-dark); font-weight: 700; }

  .food-bar {
    width: 64px;
    border-radius: 12px 12px 4px 4px;
    background: #f0c0d0;
    transition: all 0.25s;
    position: relative;
  }
  .food-bar-label {
    font-family: 'Caveat', cursive;
    font-size: 1rem;
    color: var(--muted);
    text-align: center;
    max-width: 80px;
    line-height: 1.2;
    transition: color 0.2s;
  }
  .food-bar-emoji { font-size: 1.5rem; }

  /* DIVIDER */
  .divider {
    border: none;
    border-top: 2px dashed #f9c6dc;
    margin: 1.75rem 0;
  }

  /* BOTTOM NAV */
  .nav-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
  }

  .btn-back {
    font-family: 'Caveat', cursive;
    font-size: 1.2rem;
    font-weight: 600;
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    border: 2px solid #e0c0c8;
    background: white;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-back:hover { border-color: var(--pink); color: var(--brown); }

  .btn-next {
    font-family: 'Caveat', cursive;
    font-size: 1.3rem;
    font-weight: 700;
    padding: 0.65rem 2rem;
    border-radius: 50px;
    border: none;
    background: var(--pink-dark);
    color: white;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 16px rgba(232,100,154,0.35);
  }
  .btn-next:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(232,100,154,0.5); }
  .btn-next:active { transform: scale(0.97); }
  .btn-next:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

  /* RESULTS PAGE */
  .result-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1.5px dashed #f9c6dc;
  }
  .result-row:last-child { border-bottom: none; }
  .result-icon { font-size: 1.6rem; }
  .result-label {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.1;
  }
  .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--brown);
    line-height: 1.1;
  }

  .confetti-wrap { text-align: center; font-size: 2rem; margin-bottom: 0.5rem; }

  /* Progress dots */
  .progress-dots {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #f0c0d0;
    transition: all 0.3s;
  }
  .dot.active { background: var(--pink-dark); transform: scale(1.3); }
  .dot.done { background: #c0e0c0; }

  /* Confetti burst */
  @keyframes pop { 0% { transform: scale(0) rotate(0); opacity:1; } 100% { transform: scale(1.5) rotate(360deg); opacity:0; } }
</style>
</head>
<body>


<!-- ===================== PAGE 1: THE BIG QUESTION ===================== -->
<div class="page active" id="page1">
  <div class="card">
 <img class="sticker" src="https://i.imgur.com/7AW21bd.png" alt="sticker" style="width:80px;height:80px;object-fit:contain;display:block;margin:0 auto 0.5rem;">
    <h1>Will you go out on a date with me?</h1>
    <p class="subtitle"></p>

    <div class="choices">
      <button class="choice-btn btn-no" id="noBtn" onclick="clickNo()">
        Nope
      </button>
      <button class="choice-btn btn-yes" onclick="goToPage('page2')">
        Yes
      </button>
    </div>
    <p class="wala-msg" id="walaMsg">WALA KANG CHOICE.</p>
  </div>

  <div class="progress-dots">
    <div class="dot active"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>
</div>

<!-- ===================== PAGE 2: TIME + PLACE + FOOD ===================== -->
<div class="page" id="page2">
  <div class="card" style="max-width:560px;">

    <!-- SECTION: TIME -->
    <div class="section-label">What time should we meet up?</div>
    <div class="time-grid" id="timeGrid">
      <button class="time-pill" onclick="selectTime(this, '10 AM')">10 AM</button>
      <button class="time-pill" onclick="selectTime(this, '11 AM')">11 AM</button>
      <button class="time-pill" onclick="selectTime(this, '12 PM')">12 PM</button>
      <button class="time-pill" onclick="selectTime(this, '1 PM')">1 PM</button>
    </div>

    <hr class="divider">

    <!-- SECTION: PLACE -->
    <div class="section-label">Where should we go?</div>

    <!-- Special unlockable places (10 or 11 AM) -->
    <div class="places-hidden" id="specialPlaces">
      <p class="special-label">(Spots that are a little far)</p>
      <div class="places-grid" id="specialGrid">
        <div class="place-card" onclick="selectPlace(this, 'Mall of Asia')">
          <img class="place-img" src="https://i.imgur.com/mmwNRwE.jpeg" alt="Mall of Asia"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="place-img-placeholder" style="display:none">🌊</div>
          <div class="place-name">Mall of Asia</div>
        </div>
        <div class="place-card" onclick="selectPlace(this, 'Ayala Triangle Gardens')">
          <img class="place-img" src="https://i.imgur.com/XV7FIjv.jpeg" alt="Ayala Triangle Gardens"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
          <div class="place-img-placeholder" style="display:none">🌳</div>
          <div class="place-name">Ayala Triangle Gardens</div>
        </div>
      </div>
      <hr class="divider" style="margin:1rem 0;">
    </div>

    <!-- Regular places -->
    <div class="places-grid" id="regularGrid">
      <div class="place-card" onclick="selectPlace(this, 'Eastwood Mall')">
        <img class="place-img" src="https://i.imgur.com/R154Kyj.jpeg" alt="Eastwood Mall"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div class="place-img-placeholder" style="display:none">🏬</div>
        <div class="place-name">Eastwood Mall</div>
      </div>
      <div class="place-card" onclick="selectPlace(this, 'UP Town Center')">
        <img class="place-img" src="https://ak-d.tripcdn.com/images/1mi0e2224urqg8f7kF068.jpg?proc=source/trip" alt="UP Town Center"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div class="place-img-placeholder" style="display:none">🎓</div>
        <div class="place-name">UP Town Center</div>
      </div>
      <div class="place-card" onclick="selectPlace(this, 'Cubao Expo')">
        <img class="place-img" src="https://i.imgur.com/bCYU3aX.jpeg" alt="Cubao Expo"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div class="place-img-placeholder" style="display:none">🎨</div>
        <div class="place-name">Cubao Expo</div>
      </div>
      <div class="place-card" onclick="selectPlace(this, 'The Podium')">
        <img class="place-img" src="https://thepodium.com.ph/wp-content/uploads/2023/08/MHG_8332-HDR-Edit-1-e1690883106684.jpg" alt="The Podium"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div class="place-img-placeholder" style="display:none">✨</div>
        <div class="place-name">The Podium</div>
      </div>
    </div>

    <hr class="divider">

    <!-- SECTION: FOOD -->
    <div class="section-label">How much food are we eating?</div>

    <div class="food-meter">
      <div class="food-bar-wrap" onclick="selectFood(this, 'Just a few bites')">
        <div class="food-bar-emoji"></div>
        <div class="food-bar" style="height: 60px;"></div>
        <div class="food-bar-label">Little Snack</div>
      </div>
      <div class="food-bar-wrap" onclick="selectFood(this, 'Busog Lusog')">
        <div class="food-bar-emoji"></div>
        <div class="food-bar" style="height: 100px;"></div>
        <div class="food-bar-label">Medium Meal</div>
      </div>
      <div class="food-bar-wrap" onclick="selectFood(this, 'Unli Gods ')">
        <div class="food-bar-emoji"></div>
        <div class="food-bar" style="height: 150px;"></div>
        <div class="food-bar-label">Unli</div>
      </div>
    </div>

    <div class="nav-row">
      <button class="btn-back" onclick="goToPage('page1')">← undo</button>
      <button class="btn-next" id="nextBtn" onclick="goToPage('page3')" disabled>
        Confirm
      </button>
    </div>
  </div>

  <div class="progress-dots">
    <div class="dot done"></div>
    <div class="dot active"></div>
    <div class="dot"></div>
  </div>
</div>

<!-- ===================== PAGE 3: RESULTS ===================== -->
<div class="page" id="page3">
  <div class="card">
    <div class="confetti-wrap">(Screenshot and send this to me)</div>
    <h1 style="margin-bottom:0.25rem;">It's a date!!</h1>
    <p class="subtitle" style="margin-bottom:1.5rem;">here's what we're doing</p>

    <div class="result-row">
      <div class="result-icon"></div>
      <div>
        <div class="result-label">meeting at</div>
        <div class="result-value" id="res-time">—</div>
      </div>
    </div>
    <div class="result-row">
      <div class="result-icon"></div>
      <div>
        <div class="result-label">we're going to</div>
        <div class="result-value" id="res-place">—</div>
      </div>
    </div>
    <div class="result-row">
      <div class="result-icon"></div>
      <div>
        <div class="result-label">food level</div>
        <div class="result-value" id="res-food">—</div>
      </div>
    </div>

    <p style="text-align:center; margin-top:1.75rem; font-size:1.3rem; color:var(--muted);">
      See you tomorrow bunny :3
    </p>

    <div class="nav-row" style="justify-content:center;">
      <button class="btn-back" onclick="goToPage('page2')">← change something</button>
    </div>
  </div>

  <div class="progress-dots">
    <div class="dot done"></div>
    <div class="dot done"></div>
    <div class="dot active"></div>
  </div>
</div>

<script>
  // State
  let selectedTime = null;
  let selectedPlace = null;
  let selectedFood = null;
  let noClicks = 0;

  // Floating hearts setup
  const heartsContainer = document.getElementById('heartsContainer');
  const heartEmojis = ['❤️', '🩷', '💕', '💗', '🌸', '✨', '💖', '🫶'];
  for (let i = 0; i < 12; i++) {
    const h = document.createElement('span');
    h.className = 'heart-float';
    h.textContent = heartEmojis[Math.floor(Math.random() * heartEmojis.length)];
    h.style.left = Math.random() * 100 + 'vw';
    h.style.animationDuration = (8 + Math.random() * 10) + 's';
    h.style.animationDelay = (Math.random() * 10) + 's';
    h.style.fontSize = (0.8 + Math.random() * 0.8) + 'rem';
    heartsContainer.appendChild(h);
  }

  function clickNo() {
    noClicks++;
    const noBtn = document.getElementById('noBtn');
    const msg = document.getElementById('walaMsg');
    noBtn.classList.add('struck');
    msg.classList.add('show');

    const noMessages = [
      "WALA KANG CHOICE.",
      "Wala ka ngane choice",
    ];
    msg.textContent = noMessages[Math.min(noClicks - 1, noMessages.length - 1)];
  }

  function selectTime(el, value) {
    selectedTime = value;
    document.querySelectorAll('.time-pill').forEach(p => p.classList.remove('selected'));
    el.classList.add('selected');

    // Show/hide special places
    const specialDiv = document.getElementById('specialPlaces');
    if (value === '10 AM' || value === '11 AM') {
      specialDiv.classList.add('visible');
    } else {
      specialDiv.classList.remove('visible');
      // Deselect if special place was chosen
      if (selectedPlace === 'Mall of Asia' || selectedPlace === 'Ayala Triangle Gardens') {
        selectedPlace = null;
        document.querySelectorAll('.place-card').forEach(c => c.classList.remove('selected'));
      }
    }
    checkCanProceed();
  }

  function selectPlace(el, value) {
    selectedPlace = value;
    document.querySelectorAll('.place-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    checkCanProceed();
  }

  function selectFood(el, value) {
    selectedFood = value;
    document.querySelectorAll('.food-bar-wrap').forEach(b => b.classList.remove('selected'));
    el.classList.add('selected');
    checkCanProceed();
  }

  function checkCanProceed() {
    const btn = document.getElementById('nextBtn');
    if (selectedTime && selectedPlace && selectedFood) {
      btn.disabled = false;
    } else {
      btn.disabled = true;
    }
  }

  function goToPage(id) {
    // Fill results if going to page 3
    if (id === 'page3') {
      if (!selectedTime || !selectedPlace || !selectedFood) return;
      document.getElementById('res-time').textContent = selectedTime;
      document.getElementById('res-place').textContent = selectedPlace;
      document.getElementById('res-food').textContent = selectedFood;
    }

    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
</body>
</html>
